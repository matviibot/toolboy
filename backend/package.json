{
  "name": "toolboy-relay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "toolboy backend — net relay (CORS fallback for ctx.net) + discovery index.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:local": "wrangler d1 execute toolboy-index --local --file schema.sql",
    "db:remote": "wrangler d1 execute toolboy-index --remote --file schema.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250601.0",
    "typescript": "^5.6.3",
    "wrangler": "4.86.0"
  }
}
