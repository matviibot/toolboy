# toolboy client env. Copy to `.env.local` and fill in. All vars are build-time
# (Vite inlines VITE_*), so rebuild after changing.

# Base URL of the backend Worker (see backend/). When set it enables:
#   - the net-relay CORS fallback for ctx.net  (<backend>/relay)
#   - tool discovery across repos in the palette (<backend>/discover)
# Leave unset to run fully local: direct fetch only, no cross-repo discovery.
# VITE_BACKEND_URL=https://toolboy-relay.<you>.workers.dev

# Bearer token sent with /publish, matched against the backend's PUBLISH_TOKEN.
# Only needed if the backend enforces a token (a shared deployment). WARNING: VITE_*
# vars are inlined into the built bundle, so anyone who loads the app can read this.
# For a public deployment, prefer publishing from an operator script/CI with the
# token instead of shipping it to clients. Leave unset for an open/personal index.
# VITE_PUBLISH_TOKEN=<same value as the backend's PUBLISH_TOKEN>

# GitHub PAT for loading PRIVATE gh:owner/repo@ref sources. Without it, only public
# repos load (anonymous raw.githubusercontent.com); GitHub answers private repos with
# 404. With it, the loader reads through the authenticated Contents API. A fine-grained
# token with Contents: read on the repo(s) you load is enough. Same VITE_* WARNING: it
# is inlined into the built bundle — only use this for a personal/local build.
# VITE_GITHUB_TOKEN=github_pat_...
