# toolboy client env. Copy to `.env.local` and fill in. All vars are build-time
# (Vite inlines VITE_*), so rebuild after changing.

# Backend net-relay Worker URL (see backend/). When set, a ctx.net.fetch that the
# browser can't make directly (CORS) is retried through the relay. Leave unset to
# do direct fetch only — CORS-friendly APIs work without a backend.
# VITE_NET_RELAY_URL=https://toolboy-relay.<you>.workers.dev
